---
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  keywords?: string;
  locale: "en" | "ka";
  translatedSlug?: string;
  isBlogDetail?: boolean;
  hideScrollIndicator?: boolean;
  hideFooterAtTop?: boolean;
  image?: string;
  article?: boolean;
  staticFooter?: boolean;
  relativeFooter?: boolean;
}

const {
  title,
  description = "Padel Court in Kutaisi",
  keywords = "padel, kutaisi, padel club, georgia, tennis, sport",
  locale,
  translatedSlug,
  isBlogDetail = false,
  hideScrollIndicator = false,
  hideFooterAtTop = false,
  image,
  article = false,
  staticFooter = false,
  relativeFooter = false,
} = Astro.props;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/images/logo-red-square.png" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />

    <!-- Open Graph -->
    <meta property="og:type" content={article ? "article" : "website"} />
    <meta property="og:url" content={new URL(Astro.url.pathname, Astro.site)} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {image && <meta property="og:image" content={new URL(image, Astro.site)} />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={new URL(Astro.url.pathname, Astro.site)} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {image && <meta name="twitter:image" content={new URL(image, Astro.site)} />}

    <link
      href="https://fonts.googleapis.com/css2?family=Fredoka+One&family=Noto+Sans:ital,wght@0,100..900;1,100..900&family=Noto+Sans+Georgian:wght@100..900&display=swap"
      rel="stylesheet"
    />    <style is:global>
      /* Force hide all scrollbars globally */
      html::-webkit-scrollbar,
      body::-webkit-scrollbar,
      main::-webkit-scrollbar,
      #main-scroll::-webkit-scrollbar,
      *::-webkit-scrollbar {
        display: none !important;
        width: 0 !important;
        height: 0 !important;
        background: transparent !important;
      }

      html,
      body,
      main,
      #main-scroll {
        scrollbar-width: none !important; /* Firefox */
        -ms-overflow-style: none !important; /* IE and Edge */
      }
    </style>
  </head>
  <body
    class="flex flex-col h-[100dvh] overflow-hidden font-sans text-white bg-black"
    data-hide-footer-at-top={hideFooterAtTop ? "true" : "false"}
    data-static-footer={staticFooter ? "true" : "false"}
    data-relative-footer={relativeFooter ? "true" : "false"}
  >
    <!-- Scroll progress bar -->
    <div id="scroll-progress" aria-hidden="true"></div>

    <!-- Custom Padel Ball Cursor -->
    <div id="padel-cursor" aria-hidden="true"></div>

    <Navbar
      locale={locale}
      translatedSlug={translatedSlug}
      isBlogDetail={isBlogDetail}
    />
    <main
      class="flex-grow flex flex-col overflow-y-auto relative"
      id="main-scroll"
    >
      <slot />
      <!-- Scroll down indicator (shown over hero, hidden after first scroll) -->
      {
        !hideScrollIndicator && (
          <div id="scroll-indicator" aria-hidden="true">
            <!-- Universal Horizontal Text + Arrow -->
            <div class="flex flex-row items-center gap-2 md:gap-3">
              <span class="text-[0.65rem] md:text-xs tracking-[0.2em] font-medium uppercase text-white/60">scroll down</span>
              <svg class="w-4 h-4 md:w-5 md:h-5 text-white/60 animate-bounce" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
              </svg>
            </div>
          </div>
        )
      }
      <!-- Add empty space at the absolute bottom of the scroll container so content isn't covered by the floating footer when stopped -->
      {!relativeFooter && <div id="footer-spacer" class="w-full shrink-0"></div>}
      
      <!-- If relativeFooter is true, render the footer inside the regular document flow -->
      {relativeFooter && (
        <div class="w-full shrink-0 mt-auto">
          <Footer locale={locale} staticFooter={staticFooter} />
        </div>
      )}
    </main>

    <!-- If relativeFooter is false, render the floating/sliding footer overlay -->
    {!relativeFooter && (
      <div
        id="footer-container"
        class={`fixed bottom-0 left-0 w-full z-40 transition-all duration-300 ease-out ${staticFooter ? "opacity-100 translate-y-0" : hideFooterAtTop ? "opacity-0 pointer-events-none translate-y-full" : "opacity-100 transform translate-y-0"}`}
      >
        <Footer locale={locale} staticFooter={staticFooter} />
      </div>
    )}

    <script>
      // ── Padel Ball Cursor ──
      const cursor = document.getElementById("padel-cursor")!;
      let mouseX = -100,
        mouseY = -100;
      let curX = -100,
        curY = -100;
      document.addEventListener("mousemove", (e) => {
        mouseX = e.clientX;
        mouseY = e.clientY;
      });
      function animate() {
        curX += (mouseX - curX) * 0.18;
        curY += (mouseY - curY) * 0.18;
        cursor.style.transform = `translate(${curX - 18}px, ${curY - 18}px)`;
        requestAnimationFrame(animate);
      }
      animate();
      const hoverables = document.querySelectorAll(
        'nav a, header div.hidden.md\\:flex a[href*="/contact"]',
      );
      hoverables.forEach((el) => {
        el.addEventListener("mouseenter", () =>
          cursor.classList.add("cursor-hover"),
        );
        el.addEventListener("mouseleave", () =>
          cursor.classList.remove("cursor-hover"),
        );
      });

      // Hide cursor over iframes (like YouTube player) because they hijack the pointer
      const iframes = document.querySelectorAll("iframe");
      iframes.forEach((ifr) => {
        ifr.addEventListener("mouseenter", () => {
          cursor.style.opacity = "0";
        });
        ifr.addEventListener("mouseleave", () => {
          cursor.style.opacity = "1";
        });
      });

      // ── Scroll progress bar ──
      const progressBar = document.getElementById("scroll-progress");
      const mainEl = document.getElementById("main-scroll");
      const scrollIndicator = document.getElementById("scroll-indicator");
      let indicatorHidden = false;

      const isRelativeFooter = document.body.dataset.relativeFooter === "true";

      if (mainEl && progressBar) {
        const footerContainer = document.getElementById("footer-container");
        const footerSpacer = document.getElementById("footer-spacer");

        function updateFooter() {
          if (!footerContainer || !footerSpacer || !mainEl) return;

          const { scrollTop, scrollHeight, clientHeight } = mainEl;
          // Calculate height to slide exactly out of view
          const footerHeight = footerContainer.offsetHeight;
          footerSpacer.style.height = `${footerHeight}px`;

          // Apply fast and smooth transition rules
          footerContainer.style.transition =
            "opacity 0.25s ease-out, transform 0.25s ease-out";

          // Make it disappear almost immediately (after 5px of scrolling)
          const isAtTop = scrollTop <= 5;

          // Check if we are at the very bottom
          const isAtBottom =
            Math.ceil(scrollTop + clientHeight) >= scrollHeight - 2;

          const hideFooterAtTop =
            document.body.dataset.hideFooterAtTop === "true";
          const isStaticFooter =
            document.body.dataset.staticFooter === "true";

          if (isStaticFooter) {
            footerContainer.style.opacity = "1";
            footerContainer.style.pointerEvents = "auto";
            footerContainer.style.transform = "translateY(0)";
          } else if (isAtBottom || (!hideFooterAtTop && isAtTop)) {
            // Show Footer Box entirely
            footerContainer.style.opacity = "1";
            footerContainer.style.pointerEvents = "auto";
            footerContainer.style.transform = "translateY(0)";
          } else {
            // Hide Footer Box completely off screen
            footerContainer.style.opacity = "0";
            footerContainer.style.pointerEvents = "none";
            // Slide the entire black box totally out of view downwards
            footerContainer.style.transform = `translateY(${footerHeight}px)`;
          }
        }

        // Initialize state on load
        updateFooter();

        function evaluateScrollIndicatorSpace() {
          if (!scrollIndicator || !mainEl || indicatorHidden) return;
          const heroAssets = document.querySelector('.hero-assets');
          const footerEl = document.querySelector('footer');
          
          if (heroAssets && footerEl) {
            const heroRect = heroAssets.getBoundingClientRect();
            const footerRect = footerEl.getBoundingClientRect();
            
            // Normalize hero bottom to act as if user is purely at the top of the page smoothly
            const staticHeroBottom = heroRect.bottom + mainEl.scrollTop;
            
            let boundaryBottom = window.innerHeight;
            let footerVisibleHeight = 0;
            
            const isRelativeFooter = document.body.dataset.relativeFooter === "true";
            const hideFooterAtTop = document.body.dataset.hideFooterAtTop === "true";
            const footerContainer = document.getElementById('footer-container');

            // Treat the layout as if we are purely at scrollTop = 0, immune to mid-scroll animation states
            if (!isRelativeFooter && !hideFooterAtTop && footerContainer) {
              // Footer is floating and meant to be visible at the top, so we confidently block out its height
              const fRect = footerContainer.getBoundingClientRect();
              footerVisibleHeight = fRect.height;
              boundaryBottom = window.innerHeight - footerVisibleHeight;
            } else if (isRelativeFooter) {
              // Footer is in standard document flow
              const staticFooterTop = footerRect.top + mainEl.scrollTop;
              if (staticFooterTop < window.innerHeight) {
                boundaryBottom = staticFooterTop;
                footerVisibleHeight = window.innerHeight - staticFooterTop;
              }
            }

            const spaceBelow = boundaryBottom - staticHeroBottom;
            
            // Require at least 60px space between the bottom of the images and the footer for the new horizontal indicator
            if (spaceBelow < 60) {
              scrollIndicator.style.display = 'none';
            } else {
              scrollIndicator.style.display = 'flex';
              
              // Trigger smooth initial load fade-in cleanly off the base CSS class state
              requestAnimationFrame(() => {
                scrollIndicator.style.opacity = "1";
                scrollIndicator.style.transform = "translateX(-50%) translateY(0)";
              });

              // Center it between the images and the footer
              if (footerVisibleHeight > 0) {
                // Adjusting center offset slightly for the narrower horizontal layout
                const offset = 12;
                const middle = footerVisibleHeight + (spaceBelow / 2) - offset;
                scrollIndicator.style.bottom = `${middle}px`;
              } else {
                scrollIndicator.style.bottom = window.innerWidth <= 768 ? '3.5rem' : '8.5rem';
              }
            }
          }
        }

        // Initialize state on load safely triggering fade
        setTimeout(evaluateScrollIndicatorSpace, 150);
        window.addEventListener('resize', evaluateScrollIndicatorSpace);

        mainEl.addEventListener(
          "scroll",
          () => {
            const { scrollTop, scrollHeight, clientHeight } = mainEl;
            const pct =
              scrollHeight === clientHeight
                ? 0
                : (scrollTop / (scrollHeight - clientHeight)) * 100;
            progressBar.style.width = pct + "%";

            // Handle bi-directional fading for the fixed scroll indicator robustly relying on base CSS transitions
            if (scrollIndicator) {
              if (!indicatorHidden && scrollTop > 40) {
                indicatorHidden = true;
                scrollIndicator.style.opacity = "0";
                scrollIndicator.style.transform = "translateX(-50%) translateY(12px)";
                scrollIndicator.style.pointerEvents = "none";
              } else if (indicatorHidden && scrollTop <= 40) {
                indicatorHidden = false;
                scrollIndicator.style.opacity = "1";
                scrollIndicator.style.transform = "translateX(-50%) translateY(0)";
                scrollIndicator.style.pointerEvents = "auto";
                
                // Re-calculate the layout constraints safely relative to new static coords
                evaluateScrollIndicatorSpace();
              }
            }

            if (!isRelativeFooter) {
              updateFooter();
            }
          },
          { passive: true },
        );
      }
    </script>
  </body>
</html>
