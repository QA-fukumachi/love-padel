---
interface Props {
    question: string;
    answer: string;
}

const { question, answer } = Astro.props;
---

<div class="faq-item border-b border-gray-800 last:border-0">
    <button
        type="button"
        class="faq-question w-full flex justify-between items-center py-6 text-left hover:text-[var(--color-brand-blue)] transition-colors group"
        aria-expanded="false"
    >
        <span class="text-xl md:text-2xl font-bold tracking-tight"
            >{question}</span
        >
        <span class="faq-icon relative w-6 h-6 shrink-0 ml-4">
            <span
                class="absolute top-1/2 left-0 w-full h-0.5 bg-current -translate-y-1/2"
            ></span>
            <span
                class="icon-vertical absolute top-0 left-1/2 w-0.5 h-full bg-current -translate-x-1/2 transition-transform duration-300"
            ></span>
        </span>
    </button>
    <div
        class="faq-answer-container overflow-hidden max-h-0 transition-all duration-300 ease-in-out"
    >
        <div
            class="faq-answer pb-8 text-gray-400 text-lg md:text-xl leading-relaxed max-w-4xl"
        >
            {answer}
        </div>
    </div>
</div>

<script>
    function initFAQ() {
        const faqItems = document.querySelectorAll(".faq-item");

        faqItems.forEach((item) => {
            const button = item.querySelector(".faq-question");
            const container = item.querySelector(
                ".faq-answer-container",
            ) as HTMLElement;
            const verticalIcon = item.querySelector(
                ".icon-vertical",
            ) as HTMLElement;

            button?.addEventListener("click", () => {
                const isOpen = button.getAttribute("aria-expanded") === "true";

                // Close others in the same section if desired (optional)
                // Here we'll just toggle the current one

                if (isOpen) {
                    button.setAttribute("aria-expanded", "false");
                    container.style.maxHeight = "0";
                    verticalIcon.style.transform = "rotate(0deg)";
                } else {
                    button.setAttribute("aria-expanded", "true");
                    container.style.maxHeight = container.scrollHeight + "px";
                    verticalIcon.style.transform = "rotate(90deg)";
                }
            });
        });
    }

    // Initial load
    initFAQ();

    // Re-run on View Transitions if used
    document.addEventListener("astro:page-load", initFAQ);
</script>
