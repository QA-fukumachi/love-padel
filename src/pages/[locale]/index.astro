---
import BaseLayout from "../../layouts/BaseLayout.astro";
// import PadelPong from "../../components/PadelPong.astro";
import { getTranslations, isValidLocale } from "../../utils/i18n";

const { locale } = Astro.params;

if (!locale || !isValidLocale(locale)) {
  return new Response(null, { status: 404, statusText: "Not found" });
}

const t = getTranslations(locale);
---

<BaseLayout
  title={`${t["home.hero.title"]} | Love Padel`}
  description={t["home.hero.subtitle"]}
  locale={locale}
  image="/images/hero-bg.png"
>
  <div
    class="relative w-full min-h-screen flex-grow overflow-hidden flex flex-col justify-start items-center pt-16 pb-8 md:pt-12 md:pb-48"
  >
    <!-- Hero Background Image -->
    <div
      class="absolute inset-0 z-0 bg-[url('/images/hero-bg.png')] bg-cover bg-center"
    >
      <div class="absolute inset-0 bg-black bg-opacity-60"></div>
    </div>

    <!-- Hero Assets: Left & Right -->
    <div
      class="relative z-10 w-full max-w-[1600px] mx-auto px-4 md:px-6 lg:px-12 flex flex-col md:flex-row items-stretch justify-center gap-4 md:gap-6 lg:gap-8"
    >
      <!-- Left Asset -->
      <div class="relative w-full md:w-1/2 overflow-hidden shadow-2xl">
        <!-- Spacer to match right aspect ratio exactly -->
        <img
          src="https://res.cloudinary.com/dkbcjhfiy/image/upload/v1774519542/web-asset-right-1_igiz5b.jpg"
          alt=""
          class="w-full h-auto invisible pointer-events-none"
          aria-hidden="true"
        />
        <!-- Real Image (fills the spacer's box) -->
        <img
          src="https://res.cloudinary.com/dkbcjhfiy/image/upload/v1774519542/webasset-left_ys8vpi.jpg"
          alt="Padel player on red court"
          class="absolute inset-0 w-full h-full object-cover object-top"
          loading="eager"
        />
        <img
          src="https://res.cloudinary.com/dkbcjhfiy/image/upload/v1774519542/this-title-for-left-asset_f8ao7d.png"
          alt=""
          class="absolute inset-0 w-full h-full object-cover object-top pointer-events-none"
        />
      </div>
      <!-- Right Asset -->
      <div class="relative w-full md:w-1/2 overflow-hidden shadow-2xl">
        <img
          src="https://res.cloudinary.com/dkbcjhfiy/image/upload/v1774519542/web-asset-right-1_igiz5b.jpg"
          alt="Padel player on blue court"
          class="w-full h-full object-cover object-top"
          loading="eager"
        />
        <img
          src="https://res.cloudinary.com/dkbcjhfiy/image/upload/v1774519542/this-title-for-right-asset_xwqg5g.png"
          alt=""
          class="absolute inset-0 w-full h-full object-cover object-top pointer-events-none"
        />
      </div>
    </div>
  </div>

  {/* WHO WE ARE Section */}
  <section id="who-we-are" class="w-full bg-black py-20">
    <div class="max-w-[1600px] mx-auto px-6 lg:px-12">
      <h2
        class="text-4xl md:text-5xl font-bold text-white mb-8 tracking-tight uppercase"
      >
        {t["home.whoWeAre.part1"]}<span class="text-[var(--color-brand-blue)]"
          >{t["home.whoWeAre.part2"]}</span
        >
      </h2>
      <p
        class="text-gray-400 text-lg md:text-xl leading-relaxed max-w-3xl whitespace-pre-line"
      >
        {t["home.whoWeAre.description"]}
      </p>
    </div>
  </section>

  {/* ABOUT PADEL Section */}
  <section id="about-padel" class="w-full bg-black py-20">
    <div class="max-w-[1600px] mx-auto px-6 lg:px-12">
      <h2
        class="text-4xl md:text-5xl font-bold text-white mb-10 tracking-tight uppercase"
      >
        {t["home.aboutPadel.part1"]}<span class="text-[var(--color-brand-blue)]"
          >{t["home.aboutPadel.part2"]}</span
        >
      </h2>
      <!-- Content Grid -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <!-- Responsive 16:9 YouTube embed -->
        <div
          class="relative w-full aspect-video rounded-2xl overflow-hidden border border-gray-800"
        >
          <iframe
            src="https://www.youtube.com/embed/l5SxKnaTYHw"
            title="About Padel"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            allowfullscreen
            class="absolute inset-0 w-full h-full"
            loading="lazy"></iframe>
        </div>

        <!-- Text Content -->
        <div class="w-full space-y-8">
          <h3
            class="text-3xl font-bold text-[var(--color-brand-red)] tracking-tight uppercase"
          >
            {t["home.aboutPadel.whatIs"]}
          </h3>
          <p
            class="text-gray-400 text-lg md:text-xl leading-relaxed whitespace-pre-line"
          >
            {t["home.aboutPadel.description"]}
          </p>
          <div class="space-y-6 mt-8">
            <div>
              <h4
                class="text-xl font-bold text-[var(--color-brand-blue)] mb-2 uppercase"
              >
                {t["home.aboutPadel.feature1.title"]}
              </h4>
              <p class="text-gray-400 text-lg md:text-xl">
                {t["home.aboutPadel.feature1.desc"]}
              </p>
            </div>
            <div>
              <h4
                class="text-xl font-bold text-[var(--color-brand-blue)] mb-2 uppercase"
              >
                {t["home.aboutPadel.feature2.title"]}
              </h4>
              <p class="text-gray-400 text-lg md:text-xl">
                {t["home.aboutPadel.feature2.desc"]}
              </p>
            </div>
            <div>
              <h4
                class="text-xl font-bold text-[var(--color-brand-blue)] mb-2 uppercase"
              >
                {t["home.aboutPadel.feature3.title"]}
              </h4>
              <p class="text-gray-400 text-lg md:text-xl">
                {t["home.aboutPadel.feature3.desc"]}
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* CONTACT US Section */}
  <section
    id="contact-us"
    class="w-full bg-black py-20 border-t border-gray-900"
  >
    <div
      class="max-w-[1600px] mx-auto px-6 lg:px-12 flex flex-col lg:flex-row justify-between items-start gap-12"
    >
      <div>
        <h2
          class="text-4xl md:text-5xl font-bold text-[var(--color-brand-red)] mb-8 tracking-tight uppercase"
        >
          {t["home.contactUs"]}
        </h2>
        <div class="flex flex-col space-y-4">
          <a
            href="tel:+995598321555"
            class="text-[var(--color-brand-blue)] text-lg md:text-xl hover:text-[var(--color-brand-red)] transition-colors inline-block w-fit cursor-pointer"
          >
            +995 598 321 555
          </a>
          <p class="text-[var(--color-brand-blue)] text-lg md:text-xl">
            {t["contact.address.value"] || "Nikea st. 7, Kutaisi"}
          </p>
          <a
            href="mailto:lovepadelkutaisi@gmail.com"
            class="text-[var(--color-brand-blue)] text-lg md:text-xl hover:text-[var(--color-brand-red)] transition-colors inline-block w-fit cursor-pointer"
          >
            lovepadelkutaisi@gmail.com
          </a>
        </div>
      </div>

      <!-- Google Maps Embed for Nikea st. 7, Kutaisi -->
      <div
        class="w-full lg:w-2/3 lg:max-w-3xl aspect-video lg:aspect-[21/9] rounded-2xl border border-gray-800 overflow-hidden relative"
      >
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d1887.6974102983193!2d42.6841203!3d42.2472719!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x405c8d0674f17dfd%3A0xc3afbf6ee90fc367!2s7%20Nikea%20St%2C%20Kutaisi%2C%20Georgia!5e0!3m2!1sen!2sus!4v1710000000000!5m2!1sen!2sus"
          class="absolute inset-0 w-full h-full border-0"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        >
        </iframe>
      </div>
    </div>
  </section>
</BaseLayout>
