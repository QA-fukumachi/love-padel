---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getTranslations, isValidLocale } from "../../utils/i18n";

const { locale } = Astro.params;

if (!locale || !isValidLocale(locale)) {
  return new Response(null, { status: 404, statusText: "Not found" });
}

const t = getTranslations(locale);
---

<BaseLayout
  title={`${t["events.openPlay.title"]} | Love Padel`}
  description={t["events.openPlay.intro"]}
  locale={locale}
  hideScrollIndicator={true}
  image="https://res.cloudinary.com/dkbcjhfiy/image/upload/v1774608847/Firefly_4_echkxy.png"
  relativeFooter={true}
>
  <section class="w-full bg-black pt-20 md:pt-24 pb-16">
    <div class="max-w-[1400px] mx-auto px-6 lg:px-12">
      <!-- Main Header -->
      <h1
        class="text-5xl md:text-7xl font-bold text-[var(--color-brand-red)] mb-10 tracking-tight uppercase text-center"
      >
        {t["events.openPlay.title"]}
      </h1>

      <!-- Event Image -->
      <div class="w-full max-w-4xl mb-12 overflow-hidden border border-gray-800 mx-auto">
        <img
          src="https://res.cloudinary.com/dkbcjhfiy/image/upload/v1774608847/Firefly_4_echkxy.png"
          alt={t["events.openPlay.imageAlt"]}
          class="w-full aspect-video object-cover block"
          loading="eager"
        />
      </div>

      <!-- Subheading -->
      <h2
        class={`text-3xl md:text-4xl font-bold text-[var(--color-brand-blue)] mb-8 tracking-tight text-center ${locale === "ka" ? "font-nino uppercase" : ""}`}
      >
        {t["events.openPlay.heading"]}
      </h2>

      <!-- Intro text -->
      <p
        class="text-gray-400 text-lg md:text-xl leading-relaxed max-w-4xl mb-12 text-center mx-auto"
      >
        {t["events.openPlay.intro"]}
      </p>

      <!-- Event Sections -->
      <div class="space-y-12 mb-16 max-w-4xl mx-auto text-center">
        <!-- Open Play Section -->
        <div>
          <h3
            class={`text-2xl md:text-3xl font-bold text-[var(--color-brand-red)] mb-4 uppercase ${locale === "ka" ? "font-nino" : ""}`}
          >
            {t["events.openPlay.openPlay.title"]}
          </h3>
          <p class="text-gray-400 text-lg md:text-xl leading-relaxed">
            {t["events.openPlay.openPlay.desc"]}
          </p>
        </div>

        <!-- Americanos Section -->
        <div>
          <h3
            class={`text-2xl md:text-3xl font-bold text-[var(--color-brand-red)] mb-4 uppercase ${locale === "ka" ? "font-nino" : ""}`}
          >
            {t["events.openPlay.americanos.title"]}
          </h3>
          <p class="text-gray-400 text-lg md:text-xl leading-relaxed">
            {t["events.openPlay.americanos.desc"]}
          </p>
        </div>

        <!-- Socials Section -->
        <div>
          <h3
            class={`text-2xl md:text-3xl font-bold text-[var(--color-brand-red)] mb-4 uppercase ${locale === "ka" ? "font-nino" : ""}`}
          >
            {t["events.openPlay.socials.title"]}
          </h3>
          <p class="text-gray-400 text-lg md:text-xl leading-relaxed">
            {t["events.openPlay.socials.desc"]}
          </p>
        </div>
      </div>

      <!-- Outro -->
      <div class="border-t border-gray-800 pt-10 max-w-4xl mx-auto text-center">
        <p
          class="text-gray-300 text-lg md:text-xl leading-relaxed font-semibold mb-4"
        >
          {t["events.openPlay.outro1"]}
        </p>
        <p class="text-[var(--color-brand-blue)] text-lg md:text-xl font-bold uppercase">
          {t["events.openPlay.outro2"]}
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
