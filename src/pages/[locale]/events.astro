---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getTranslations, isValidLocale } from "../../utils/i18n";

const { locale } = Astro.params;

if (!locale || !isValidLocale(locale)) {
  return new Response(null, { status: 404, statusText: "Not found" });
}

const t = getTranslations(locale);
---

<BaseLayout
  title={`${t["events.openPlay.title"]} | Love Padel`}
  description={t["events.openPlay.intro"]}
  locale={locale}
  hideScrollIndicator={true}
  image="https://res.cloudinary.com/dkbcjhfiy/image/upload/v1774608847/Firefly_4_echkxy.png"
  relativeFooter={true}
>
  <section class="w-full bg-black pt-20 md:pt-24 pb-16 flex-grow flex flex-col">
    <div class="max-w-[1400px] mx-auto px-6 lg:px-12 flex flex-col flex-grow">
      
      <!-- HERO SECTION -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-start mb-16">
        <!-- Left Column: Image -->
        <div class="w-full rounded-none overflow-hidden border border-gray-800 relative shadow-2xl block aspect-video">
          <img
            src="https://res.cloudinary.com/dkbcjhfiy/image/upload/v1774608847/Firefly_4_echkxy.png"
            alt={t["events.openPlay.imageAlt"]}
            class="absolute inset-0 w-full h-full object-cover block"
            loading="eager"
          />
        </div>

        <!-- Right Column: Text Content -->
        <div class="flex flex-col justify-start">
          <h1
            class="text-4xl md:text-5xl lg:text-6xl font-bold text-[var(--color-brand-red)] mb-6 tracking-tight uppercase"
          >
            {t["events.openPlay.title"]}
          </h1>
          <h2
            class={`text-2xl md:text-3xl lg:text-4xl font-bold text-[var(--color-brand-blue)] mb-8 tracking-tight ${locale === "ka" ? "font-nino uppercase" : ""}`}
          >
            {t["events.openPlay.heading"]}
          </h2>
          <p
            class="text-gray-400 text-lg md:text-xl leading-relaxed whitespace-pre-line"
          >
            {t["events.openPlay.intro"]}
          </p>
        </div>
      </div>

      <!-- EVENT SECTIONS (Simple Layout) -->
      <div class="flex flex-col space-y-12 mb-16 max-w-5xl">
        <!-- Open Play -->
        <div>
          <h3
            class={`text-2xl md:text-3xl font-bold text-[var(--color-brand-red)] mb-4 uppercase ${locale === "ka" ? "font-nino" : ""}`}
          >
            {t["events.openPlay.openPlay.title"]}
          </h3>
          <p class="text-gray-400 text-lg md:text-xl leading-relaxed">
            {t["events.openPlay.openPlay.desc"]}
          </p>
        </div>

        <!-- Americanos -->
        <div>
          <h3
            class={`text-2xl md:text-3xl font-bold text-[var(--color-brand-red)] mb-4 uppercase ${locale === "ka" ? "font-nino" : ""}`}
          >
            {t["events.openPlay.americanos.title"]}
          </h3>
          <p class="text-gray-400 text-lg md:text-xl leading-relaxed">
            {t["events.openPlay.americanos.desc"]}
          </p>
        </div>

        <!-- Socials -->
        <div>
          <h3
            class={`text-2xl md:text-3xl font-bold text-[var(--color-brand-red)] mb-4 uppercase ${locale === "ka" ? "font-nino" : ""}`}
          >
            {t["events.openPlay.socials.title"]}
          </h3>
          <p class="text-gray-400 text-lg md:text-xl leading-relaxed">
            {t["events.openPlay.socials.desc"]}
          </p>
        </div>
      </div>

      <!-- OUTRO SECTION -->
      <div class="border-t border-gray-800 pt-10 mt-auto w-full max-w-5xl">
        <p
          class="text-gray-400 text-lg md:text-xl leading-relaxed font-semibold mb-4 whitespace-pre-line"
        >
          {t["events.openPlay.outro1"]}
        </p>
        <p class="text-[var(--color-brand-blue)] text-lg md:text-xl font-bold uppercase tracking-wide">
          {t["events.openPlay.outro2"]}
        </p>
      </div>

    </div>
  </section>
</BaseLayout>

