---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PortableText from "../../../components/PortableText.astro";
import { sanityClient, urlFor } from "../../../sanity/client";
import { getSingleBlogPostQuery } from "../../../sanity/queries";
import { getTranslations, isValidLocale } from "../../../utils/i18n";

const { locale, slug } = Astro.params;

if (!locale || !isValidLocale(locale) || !slug) {
  return new Response(null, { status: 404, statusText: "Not found" });
}

const t = getTranslations(locale);

// Fetch the single post
const post = await sanityClient.fetch(getSingleBlogPostQuery, {
  locale,
  slug,
});

if (!post) {
  return new Response(null, { status: 404, statusText: "Not found" });
}

let imageUrl = "/images/placeholder-blog.jpg";
if (post.image) {
  imageUrl = urlFor(post.image).width(1920).auto("format").url();
}

const formattedDate = new Date(post.publishDate).toLocaleDateString(
  locale === "ka" ? "ka-GE" : "en-US",
  {
    year: "numeric",
    month: "long",
    day: "numeric",
  },
);

const isGeorgian = locale === "ka";
---

<BaseLayout
  title={`${post.title} | Love Padel`}
  description={post.excerpt || post.title}
  locale={locale}
  translatedSlug={post.translatedSlug}
  isBlogDetail={true}
  hideScrollIndicator={true}
  hideFooterAtTop={true}
  image={imageUrl}
  article={true}
>
  <div
    id="reading-progress"
    class="fixed top-0 left-0 h-1 bg-[var(--color-brand-blue)] z-50 transition-all duration-150 ease-out w-0"
  >
  </div>

  <article
    class="w-full relative bg-[var(--color-bg-primary)] overflow-x-hidden"
  >
    {/* MASSIVE HERO SECTION */}
    <header
      class="relative flex flex-col justify-end px-6 md:px-12 lg:px-24 pb-8 md:pb-16 pt-0"
      id="blog-hero"
    >
      <div
        class="absolute top-0 right-0 w-full max-w-3xl h-full max-h-3xl bg-brandPrimary/10 blur-[140px] rounded-full pointer-events-none -translate-y-1/3 translate-x-1/4"
      >
      </div>

      <div
        class="w-full max-w-[1400px] mx-auto relative z-10 flex flex-col lg:flex-row gap-8 lg:items-end justify-between"
      >
        {/* Title Area */}
        <div
          class="w-full lg:w-4/5 xl:w-5/6 flex flex-col items-start text-left"
        >
          <div
            class="hero-element transition-all duration-1000 ease-[cubic-bezier(0.19,1,0.22,1)] will-change-transform mb-6"
          >
            <span
              class="inline-block px-4 py-1.5 rounded-full border border-[var(--color-brand-blue)] text-[var(--color-brand-blue)] text-xs font-bold tracking-widest uppercase"
            >
              Blog
            </span>
          </div>

          <h1
            class={`hero-element transition-all duration-1000 delay-100 ease-[cubic-bezier(0.19,1,0.22,1)] will-change-transform font-black text-[var(--color-text-primary)] tracking-tight mb-8 w-full ${isGeorgian ? "text-3xl md:text-5xl lg:text-6xl xl:text-7xl leading-[1.2]" : "text-4xl md:text-6xl lg:text-7xl xl:text-8xl leading-[1.0]"}`}
          >
            {post.title}
          </h1>

          {/* Meta & Actions */}
          <div
            class="hero-element transition-all duration-1000 delay-200 ease-[cubic-bezier(0.19,1,0.22,1)] will-change-transform flex flex-wrap justify-start items-center gap-6 md:gap-8"
          >
            <div class="flex items-center gap-4">
              {
                post.author?.imageUrl && (
                  <div class="w-12 h-12 rounded-full overflow-hidden border-2 border-[var(--color-bg-primary)] shadow-md">
                    <img
                      src={post.author.imageUrl}
                      alt={post.author.name}
                      class="w-full h-full object-cover"
                    />
                  </div>
                )
              }
              <div>
                <p
                  class="text-[var(--color-text-primary)] font-bold text-lg leading-tight"
                >
                  {post.author?.name || "Love Padel"}
                </p>
                <p class="text-brandSecondary font-medium text-sm">
                  {formattedDate}
                </p>
              </div>
            </div>

            {
              post.translatedSlug && (
                <div class="w-px h-10 bg-gray-200 hidden md:block" />
              )
            }

            {
              post.translatedSlug && (
                <a
                  href={`/${locale === "en" ? "ka" : "en"}/blog/${post.translatedSlug}`}
                  class="group flex items-center gap-2 bg-[var(--color-bg-secondary)] hover:bg-[var(--color-brand-blue)] px-6 py-3 rounded-full transition-all duration-500 hover:shadow-lg hover:shadow-brandPrimary/30"
                >
                  <span class="text-[var(--color-text-primary)] group-hover:text-white font-bold transition-colors">
                    {t["blog.readIn"]}
                  </span>
                  <svg
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="w-5 h-5 text-[var(--color-brand-blue)] group-hover:text-white transition-colors"
                  >
                    <>
                      <path d="m5 8 6 6" />
                      <path d="m4 14 6-6 2-3" />
                      <path d="M2 5h12" />
                      <path d="M7 2h1" />
                      <path d="m22 22-5-10-5 10" />
                      <path d="M14 18h6" />
                    </>
                  </svg>
                </a>
              )
            }
          </div>
        </div>
      </div>
    </header>

    {/* HERO IMAGE SECTION */}
    <div class="w-full px-6 md:px-8 lg:px-12 mb-20 lg:mb-32">
      <div
        class="w-full max-w-[1400px] mx-auto rounded-[2rem] md:rounded-[3rem] overflow-hidden will-change-transform shadow-2xl relative bg-black flex items-center justify-center"
        id="hero-image-container"
      >
        <div
          class="absolute inset-0 bg-brandPrimary/5 mix-blend-multiply z-10 pointer-events-none"
        >
        </div>
        <img
          src={imageUrl}
          alt={post.image?.alt || post.title}
          id="hero-image"
          class="max-w-full h-auto max-h-[60vh] md:max-h-[85vh] object-contain rounded-[2rem] md:rounded-[3rem] will-change-transform shadow-lg"
        />
      </div>
    </div>

    {/* CONTENT SECTION */}
    <div class="w-full max-w-4xl mx-auto px-6 pb-32">
      <div class="content-element w-full">
        <PortableText value={post.content} />
      </div>

      {/* Share / Footer of Article */}
      <div
        class="mt-24 pt-12 border-t border-[var(--color-border)] flex flex-col items-center justify-center text-center"
      >
        <p class="text-2xl font-bold text-[var(--color-text-primary)] mb-6">
          {isGeorgian ? "მოგეწონათ ბლოგი?" : "Enjoyed this reading?"}
        </p>
        <div class="flex flex-wrap justify-center gap-6 mt-4">
          {/* Facebook */}
          <button
            class="w-12 h-12 rounded-full border border-gray-700 flex items-center justify-center text-gray-400 hover:text-[var(--color-brand-blue)] hover:border-[var(--color-brand-blue)] transition-colors group"
          >
            <svg
              viewBox="0 0 24 24"
              fill="currentColor"
              class="w-5 h-5 transition-colors"
              ><path
                d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"
              ></path></svg
            >
          </button>
          {/* Instagram */}
          <button
            class="w-12 h-12 rounded-full border border-gray-700 flex items-center justify-center text-gray-400 hover:text-pink-500 hover:border-pink-500 transition-colors group"
          >
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="w-5 h-5 transition-colors"
              ><rect x="2" y="2" width="20" height="20" rx="5" ry="5"
              ></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"
              ></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg
            >
          </button>
          {/* Copy Link */}
          <button
            onclick="copyArticleLink(this)"
            class="relative w-12 h-12 rounded-full border border-gray-700 flex items-center justify-center text-gray-400 hover:text-white hover:border-white transition-colors group"
          >
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="w-5 h-5 transition-colors"
              ><path
                d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"
              ></path><path
                d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"
              ></path></svg
            >
          </button>
        </div>
      </div>
    </div>
  </article>

  <style>
    /* Styling for the progress bar specifically */
    #reading-progress {
      will-change: width;
      transform: translateZ(0); /* Hardware acceleration */
    }

    /* CSS-based robust scroll reveal class for content */
    .content-element {
      transition:
        opacity 1s cubic-bezier(0.19, 1, 0.22, 1),
        transform 1s cubic-bezier(0.19, 1, 0.22, 1);
      will-change: opacity, transform;
    }
    .content-element.is-visible {
      opacity: 1;
      transform: translateY(0);
    }
  </style>

  <script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    const initAnimations = () => {
      // Determine the scroll container if using a fixed layout
      const scroller = document.getElementById("main-scroll") || document.body;
      // 1. Initial Hero Reveal Animation
      const heroElements = document.querySelectorAll(".hero-element");

      // Reset state for page transitions
      gsap.set(heroElements, { opacity: 0, y: 40 });
      gsap.set("#hero-image-container", {
        scale: 0.95,
        opacity: 0,
        y: 60,
      });

      const tl = gsap.timeline();

      tl.to(heroElements, {
        opacity: 1,
        y: 0,
        duration: 1.2,
        stagger: 0.15,
        ease: "power4.out",
        delay: 0.2,
      }).to(
        "#hero-image-container",
        {
          opacity: 1,
          y: 0,
          scale: 1,
          duration: 1.5,
          ease: "power3.out",
        },
        "-=0.8",
      );

      // 2. Parallax Image Scroll Effect
      const imageContainer = document.getElementById("hero-image-container");

      if (imageContainer) {
        // Subtle scale down and blur of the hero text on scroll
        gsap.to(document.getElementById("blog-hero"), {
          y: 100,
          opacity: 0,
          ease: "none",
          scrollTrigger: {
            trigger: "#main-scroll", // the scroll container itself
            scroller: scroller,
            start: "top top",
            end: "top -50%",
            scrub: true,
          },
        });
      }

      // 3. Robust Content Reveal on Scroll (Native IntersectionObserver)
      const contentElements = document.querySelectorAll(".content-element");

      const observerOptions = {
        root: scroller === document.body ? null : scroller,
        rootMargin: "0px 0px -10% 0px", // Trigger when element is 10% from bottom
        threshold: 0,
      };

      const observer = new IntersectionObserver((entries, obs) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            obs.unobserve(entry.target); // Only animate once
          }
        });
      }, observerOptions);

      contentElements.forEach((el) => {
        observer.observe(el);
      });

      // 4. Reading Progress Bar
      const progressBar = document.getElementById("reading-progress");
      if (progressBar) {
        gsap.to(progressBar, {
          width: "100%",
          ease: "none",
          scrollTrigger: {
            trigger: "#main-scroll", // the scroll container
            scroller: scroller,
            start: "top top",
            end: "bottom bottom",
            scrub: 0.3, // slight smoothing
          },
        });
      }

      // Failsafe: occasionally web fonts or nested components shift layout after a fraction of a second.
      setTimeout(() => {
        ScrollTrigger.refresh();
      }, 500);
    };

    // Run animations immediately (Astro scripts are deferred, so DOM is ready)
    initAnimations();

    // Also listen for Astro page load in case ViewTransitions are ever added
    document.addEventListener("astro:page-load", initAnimations);
  </script>

  <script is:inline>
    function copyArticleLink(btn) {
      var url = window.location.href;

      // Copy to clipboard with fallback
      if (navigator.clipboard && window.isSecureContext) {
        navigator.clipboard.writeText(url);
      } else {
        var ta = document.createElement("textarea");
        ta.value = url;
        ta.style.position = "fixed";
        ta.style.left = "-9999px";
        document.body.appendChild(ta);
        ta.focus();
        ta.select();
        document.execCommand("copy");
        ta.remove();
      }

      // Remove old tooltip if exists
      var old = document.getElementById("copy-toast");
      if (old) old.remove();

      // Create tooltip element
      var toast = document.createElement("div");
      toast.id = "copy-toast";
      toast.textContent =
        document.documentElement.lang === "ka"
          ? "ლინკი დაკოპირდა!"
          : "Link Copied!";
      toast.style.cssText =
        "position:fixed;z-index:99999;background:#38a1da;color:#fff;font-size:13px;font-weight:700;padding:10px 20px;border-radius:10px;box-shadow:0 8px 24px rgba(0,0,0,0.4);pointer-events:none;transition:opacity 0.3s ease,transform 0.3s ease;opacity:0;transform:translate(-50%,8px);white-space:nowrap;";

      document.body.appendChild(toast);

      // Position above button
      var r = btn.getBoundingClientRect();
      toast.style.top = r.top - 50 + "px";
      toast.style.left = r.left + r.width / 2 + "px";

      // Animate in
      requestAnimationFrame(function () {
        requestAnimationFrame(function () {
          toast.style.opacity = "1";
          toast.style.transform = "translate(-50%, 0)";
        });
      });

      // Fade out after 2s
      setTimeout(function () {
        toast.style.opacity = "0";
        toast.style.transform = "translate(-50%, 8px)";
        setTimeout(function () {
          toast.remove();
        }, 400);
      }, 2000);
    }
  </script>
</BaseLayout>
