---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import BlogCard from "../../../components/BlogCard.astro";
import { sanityClient } from "../../../sanity/client";
import { getBlogPostsQuery } from "../../../sanity/queries";
import { getTranslations, isValidLocale } from "../../../utils/i18n";

const { locale } = Astro.params;

if (!locale || !isValidLocale(locale)) {
  return new Response(null, { status: 404, statusText: "Not found" });
}

const t = getTranslations(locale);

// Fetch posts
const posts = await sanityClient.fetch(getBlogPostsQuery, { locale });
---

<BaseLayout
  title={`${t["blog.title"]} | Love Padel`}
  description={t["blog.title"]}
  locale={locale}
  hideScrollIndicator={true}
  hideFooterAtTop={true}
  image="/images/hero-bg.png"
>
  <div class="max-w-7xl mx-auto px-4 py-16 md:py-24">
    <div class="text-center mb-16">
      <h1
        class="text-4xl md:text-5xl font-extrabold text-[var(--color-brand-blue)] uppercase"
      >
        {t["blog.title"]}
      </h1>
    </div>

    {
      posts.length === 0 ? (
        <div class="text-center py-20 bg-gray-50 rounded-2xl border border-gray-100">
          <p class="text-xl text-gray-500 font-medium">{t["blog.empty"]}</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {posts.map((post: any) => (
            <BlogCard
              title={post.title}
              slug={post.slug.current}
              excerpt={post.excerpt}
              image={post.image}
              publishDate={post.publishDate}
              author={post.author}
              locale={locale}
            />
          ))}
        </div>
      )
    }
  </div>
</BaseLayout>
